# Database (Supabase / PostgreSQL)
DATABASE_URL=
DIRECT_URL=

# SEEK Employer scraper → POST /api/candidates/import-seek (x-api-key header)
# Example value for local dev only — set your own secret in production
SEEK_IMPORT_KEY=nuanu-seek-secret-2026
# Auto-create published vacancies for SEEK roles (Site Manager, Accounting Officer, …)
# SEEK_AUTO_CREATE_VACANCIES=true
# Optional: map SEEK role titles to existing vacancy IDs instead of auto-create
# SEEK_VACANCY_SITE_MANAGER=
# SEEK_VACANCY_ACCOUNTING_OFFICER=

# Absolute path to seek-scraper/scrape-checkpoint.json (read by /api/seek/salary
# to resolve cached salary expectations). Falls back to ../seek-scraper/… when unset.
# SEEK_CHECKPOINT_PATH=/home/dendy/seek-scraper/scrape-checkpoint.json

# JobStreet webhook (optional)
JOBSTREET_WEBHOOK_SECRET=

# ── AI / CV parsing ──────────────────────────────────────────────────────────
# Groq API key for CV parsing (llama-3.3-70b-versatile).
# GROQ_API_KEY is preferred. AI_API_KEY is read as a fallback for backward
# compatibility with existing deployments that already have it set.
GROQ_API_KEY=
# Legacy fallback (still supported by the CV parser)
AI_API_KEY=
AI_API_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
# Optional local Ollama fallback (skipped on Vercel)
# OLLAMA_URL=http://localhost:11434
