generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// AUTH & ACCESS CONTROL
// ==========================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  avatar        String?
  phone         String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  userRoles       UserRole[]
  approvals       Approval[]       @relation("ApproverApprovals")
  requestedApprovals Approval[]    @relation("RequesterApprovals")
  applications    Application[]
  interviewFeedback InterviewFeedback[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  scheduledInterviews Interview[]  @relation("InterviewerInterviews")
  createdVacancies Vacancy[]       @relation("VacancyCreator")
  assignedVacancies Vacancy[]      @relation("VacancyRecruiter")
  onboardingTasks OnboardingTask[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String @id @default(uuid())
  name     String @unique
  resource String
  action   String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==========================================
// ORGANIZATION
// ==========================================

model Department {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  headId      String?
  description String?
  budget      Float     @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users       User[]
  vacancies   Vacancy[]
  budgets     Budget[]

  @@map("departments")
}

model Budget {
  id           String   @id @default(uuid())
  departmentId String
  fiscalYear   Int
  totalAmount  Float
  spentAmount  Float    @default(0)
  currency     String   @default("USD")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, fiscalYear])
  @@map("budgets")
}

// ==========================================
// JOB REQUISITIONS
// ==========================================

model Vacancy {
  id              String    @id @default(uuid())
  title           String
  code            String    @unique
  departmentId    String
  creatorId       String
  recruiterId     String?
  description     String?
  requirements    String?
  responsibilities String?
  skills          String[]
  experienceMin   Int       @default(0)
  experienceMax   Int?
  educationLevel  String?
  employmentType  String    @default("full-time")
  locationType    String    @default("onsite")
  location        String?
  salaryMin       Float?
  salaryMax       Float?
  currency        String    @default("USD")
  headcount       Int       @default(1)
  filledCount     Int       @default(0)
  priority        String    @default("medium")
  status          String    @default("draft")
  publishedAt     DateTime?
  closedAt        DateTime?
  targetHireDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  department    Department    @relation(fields: [departmentId], references: [id])
  creator       User          @relation("VacancyCreator", fields: [creatorId], references: [id])
  recruiter     User?         @relation("VacancyRecruiter", fields: [recruiterId], references: [id])
  approvals     Approval[]
  jobPostings   JobPosting[]
  applications  Application[]

  @@index([status])
  @@index([departmentId])
  @@map("vacancies")
}

model JobProfile {
  id             String   @id @default(uuid())
  title          String
  category       String?
  description    String?
  requirements   String?
  skills         String[]
  experienceMin  Int      @default(0)
  experienceMax  Int?
  educationLevel String?
  isTemplate     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("job_profiles")
}

// ==========================================
// APPROVAL WORKFLOW
// ==========================================

model Approval {
  id          String    @id @default(uuid())
  vacancyId   String
  requesterId String
  approverId  String
  type        String    // hiring_manager, hr, finance, headcount
  status      String    @default("pending") // pending, approved, rejected
  level       Int       @default(1)
  comments    String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vacancy     Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  requester   User    @relation("RequesterApprovals", fields: [requesterId], references: [id])
  approver    User    @relation("ApproverApprovals", fields: [approverId], references: [id])

  @@index([vacancyId])
  @@index([approverId, status])
  @@map("approvals")
}

// ==========================================
// JOB POSTINGS
// ==========================================

model JobPosting {
  id          String    @id @default(uuid())
  vacancyId   String
  channel     String    // linkedin, indeed, jobstreet, internal
  externalId  String?
  externalUrl String?
  status      String    @default("draft")
  views       Int       @default(0)
  clicks      Int       @default(0)
  applies     Int       @default(0)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vacancy     Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  @@index([vacancyId])
  @@index([channel])
  @@map("job_postings")
}

// ==========================================
// APPLICANT TRACKING
// ==========================================

model Application {
  id              String    @id @default(uuid())
  vacancyId       String
  candidateId     String
  source          String    @default("direct")
  status          String    @default("applied")
  currentStage    String    @default("applied")
  coverLetter     String?
  referralSource  String?
  referralName    String?
  tags            String[]
  isStarred       Boolean   @default(false)
  appliedAt       DateTime  @default(now())
  lastActivityAt  DateTime  @default(now())
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  vacancy         Vacancy   @relation(fields: [vacancyId], references: [id])
  candidate       User      @relation(fields: [candidateId], references: [id])
  candidateScore  CandidateScore?
  pipelineStages  PipelineStage[]
  interviews      Interview[]
  assessments     Assessment[]
  offer           Offer?
  documents       Document[]

  @@unique([vacancyId, candidateId])
  @@index([status])
  @@index([currentStage])
  @@index([vacancyId])
  @@map("applications")
}

model CandidateProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  headline       String?
  summary        String?
  skills         String[]
  experienceYears Int     @default(0)
  currentTitle   String?
  currentCompany String?
  education      String?
  linkedinUrl    String?
  portfolioUrl   String?
  resumeUrl      String?
  resumeText     String?
  parsedData     Json?
  location       String?
  willingToRelocate Boolean @default(false)
  expectedSalary Float?
  noticePeriod   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("candidate_profiles")
}

model Document {
  id            String   @id @default(uuid())
  applicationId String
  name          String
  type          String   // resume, cover_letter, certificate, portfolio
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  createdAt     DateTime @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ==========================================
// AI SCORING
// ==========================================

model CandidateScore {
  id              String   @id @default(uuid())
  applicationId   String   @unique
  overallScore    Float    @default(0)
  hardSkillsScore Float    @default(0)
  softSkillsScore Float    @default(0)
  experienceScore Float    @default(0)
  educationScore  Float    @default(0)
  formatScore     Float    @default(0)
  matchedKeywords String[]
  missingKeywords String[]
  skillGaps       String[]
  strengths       String[]
  recommendations String[]
  breakdown       Json?
  scoredAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([overallScore])
  @@map("candidate_scores")
}

// ==========================================
// PIPELINE
// ==========================================

model PipelineStage {
  id            String    @id @default(uuid())
  applicationId String
  stage         String
  enteredAt     DateTime  @default(now())
  exitedAt      DateTime?
  duration      Int?      // in minutes
  movedBy       String?
  notes         String?

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([stage])
  @@map("pipeline_stages")
}

// ==========================================
// INTERVIEWS
// ==========================================

model Interview {
  id              String    @id @default(uuid())
  applicationId   String
  interviewerId   String
  type            String    @default("phone") // phone, video, onsite, panel
  stage           String    @default("hr_interview")
  scheduledAt     DateTime
  duration        Int       @default(60) // minutes
  location        String?
  meetingUrl      String?
  status          String    @default("scheduled") // scheduled, confirmed, completed, cancelled, rescheduled
  calendarEventId String?
  notes           String?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewer     User        @relation("InterviewerInterviews", fields: [interviewerId], references: [id])
  feedback        InterviewFeedback[]

  @@index([applicationId])
  @@index([interviewerId])
  @@index([scheduledAt])
  @@map("interviews")
}

model InterviewFeedback {
  id            String   @id @default(uuid())
  interviewId   String
  interviewerId String
  overallRating Int      // 1-5
  technicalScore Int?    // 1-10
  communicationScore Int? // 1-10
  cultureFitScore Int?   // 1-10
  leadershipScore Int?   // 1-10
  strengths     String?
  weaknesses    String?
  recommendation String  @default("neutral") // strong_hire, hire, neutral, no_hire, strong_no_hire
  notes         String?
  isSubmitted   Boolean  @default(false)
  submittedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewer   User      @relation(fields: [interviewerId], references: [id])

  @@unique([interviewId, interviewerId])
  @@map("interview_feedback")
}

// ==========================================
// ASSESSMENTS
// ==========================================

model Assessment {
  id            String    @id @default(uuid())
  applicationId String
  type          String    // skill_test, personality, cognitive, questionnaire
  title         String
  description   String?
  questions     Json?
  answers       Json?
  score         Float?
  maxScore      Float?
  status        String    @default("pending") // pending, in_progress, completed, expired
  passThreshold Float?
  isPassed      Boolean?
  startedAt     DateTime?
  completedAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("assessments")
}

model AssessmentTemplate {
  id          String   @id @default(uuid())
  title       String
  type        String
  description String?
  questions   Json
  duration    Int?     // minutes
  passThreshold Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("assessment_templates")
}

// ==========================================
// OFFERS & CONTRACTS
// ==========================================

model Offer {
  id              String    @id @default(uuid())
  applicationId   String    @unique
  salary          Float
  currency        String    @default("USD")
  salaryPeriod    String    @default("annual")
  bonus           Float?
  equity          String?
  benefits        String?
  startDate       DateTime?
  expiresAt       DateTime?
  status          String    @default("draft") // draft, pending_approval, approved, sent, accepted, rejected, expired
  documentUrl     String?
  sentAt          DateTime?
  respondedAt     DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  application     Application @relation(fields: [applicationId], references: [id])
  contract        Contract?

  @@map("offers")
}

model Contract {
  id            String    @id @default(uuid())
  offerId       String    @unique
  type          String    @default("full-time")
  documentUrl   String?
  signedAt      DateTime?
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("pending") // pending, sent, signed, active, terminated
  eSignatureId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  offer         Offer @relation(fields: [offerId], references: [id])

  @@map("contracts")
}

// ==========================================
// ONBOARDING
// ==========================================

model OnboardingTask {
  id          String    @id @default(uuid())
  employeeId  String
  title       String
  description String?
  category    String    @default("general") // general, documentation, training, it_setup, compliance
  priority    Int       @default(1)
  status      String    @default("pending") // pending, in_progress, completed, overdue
  dueDate     DateTime?
  completedAt DateTime?
  assignedTo  String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee    User @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("onboarding_tasks")
}

// ==========================================
// NOTIFICATIONS & ACTIVITY
// ==========================================

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String    // approval, interview, offer, system, reminder
  title     String
  message   String
  link      String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  resource  String
  resourceId String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ==========================================
// INTEGRATIONS
// ==========================================

model Integration {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String   // job_board, calendar, email, messaging, hris
  config      Json?
  isActive    Boolean  @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("integrations")
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  events    String[]
  secret    String?
  isActive  Boolean  @default(true)
  lastTriggeredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}
